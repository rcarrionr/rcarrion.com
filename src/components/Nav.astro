---
const links = [
	{ href: '#about', label: 'About' },
	{ href: '#projects', label: 'Projects' },
	{ href: '#experience', label: 'Experience' },
	{ href: '#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
	<nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
		<a href="#" class="font-semibold tracking-tight text-slate-100">Richard Carrion</a>
		<ul class="flex gap-6 text-sm text-slate-400">
			{links.map((link) => (
				<li>
					<a href={link.href} class="transition-colors hover:text-slate-100">{link.label}</a>
				</li>
			))}
		</ul>
	</nav>
</header>
